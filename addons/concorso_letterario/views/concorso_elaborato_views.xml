<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Elaborato: form view -->
    <record id="view_concorso_elaborato_form" model="ir.ui.view">
        <field name="name">concorso.elaborato.form</field>
        <field name="model">concorso.elaborato</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="stato" widget="statusbar"
                           statusbar_visible="bozza,inviato,in_valutazione,valutato,premiato"/>
                </header>
                <sheet>
                    <group>
                        <group string="Informazioni Elaborato">
                            <field name="name"/>
                            <field name="edizione_id"/>
                            <field name="sezione_id"/>
                            <field name="sottosezione_id"/>
                        </group>
                        <group string="Partecipante">
                            <field name="partecipante_id"/>
                        </group>
                    </group>
                    <group string="Valutazione">
                        <field name="media_punteggi"/>
                        <field name="posizione_ranking"/>
                    </group>
                    <notebook>
                        <page string="Note Commissione">
                            <field name="note"/>
                        </page>
                        <page string="File Allegati">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Elaborato: list view -->
    <record id="view_concorso_elaborato_list" model="ir.ui.view">
        <field name="name">concorso.elaborato.list</field>
        <field name="model">concorso.elaborato</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partecipante_id"/>
                <field name="edizione_id"/>
                <field name="sezione_id"/>
                <field name="sottosezione_id"/>
                <field name="stato"/>
                <field name="media_punteggi"/>
                <field name="posizione_ranking"/>
            </list>
        </field>
    </record>

    <!-- Elaborato: search view -->
    <record id="view_concorso_elaborato_search" model="ir.ui.view">
        <field name="name">concorso.elaborato.search</field>
        <field name="model">concorso.elaborato</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partecipante_id"/>
                <field name="edizione_id"/>
                <filter string="Valutati" name="valutati" domain="[('stato','=','valutato')]"/>
                <filter string="Premiati" name="premiati" domain="[('stato','=','premiato')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Edizione" name="group_edizione" context="{'group_by': 'edizione_id'}"/>
                    <filter string="Sezione" name="group_sezione" context="{'group_by': 'sezione_id'}"/>
                    <filter string="Sottosezione" name="group_sottosezione" context="{'group_by': 'sottosezione_id'}"/>
                    <filter string="Stato" name="group_stato" context="{'group_by': 'stato'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Elaborato: action -->
    <record id="action_concorso_elaborato" model="ir.actions.act_window">
        <field name="name">Elaborati</field>
        <field name="res_model">concorso.elaborato</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
