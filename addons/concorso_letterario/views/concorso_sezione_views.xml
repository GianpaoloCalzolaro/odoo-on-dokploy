<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sezione: form view -->
    <record id="view_concorso_sezione_form" model="ir.ui.view">
        <field name="name">concorso.sezione.form</field>
        <field name="model">concorso.sezione</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="edizione_id"/>
                    </group>
                    <notebook>
                        <page string="Sottosezioni">
                            <field name="sottosezione_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="eta_min"/>
                                    <field name="eta_max"/>
                                </list>
                            </field>
                        </page>
                        <page string="Note">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sezione: list view -->
    <record id="view_concorso_sezione_list" model="ir.ui.view">
        <field name="name">concorso.sezione.list</field>
        <field name="model">concorso.sezione</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="edizione_id"/>
            </list>
        </field>
    </record>

    <!-- Sezione: action -->
    <record id="action_concorso_sezione" model="ir.actions.act_window">
        <field name="name">Sezioni</field>
        <field name="res_model">concorso.sezione</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
