<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Edizione: form view -->
    <record id="view_concorso_edizione_form" model="ir.ui.view">
        <field name="name">concorso.edizione.form</field>
        <field name="model">concorso.edizione</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_apri" string="Apri" type="object"
                            invisible="stato != 'bozza'" class="btn-primary"/>
                    <button name="action_chiudi" string="Chiudi" type="object"
                            invisible="stato != 'aperto'"/>
                    <button name="action_archivia" string="Archivia" type="object"
                            invisible="stato != 'chiuso'"/>
                    <field name="stato" widget="statusbar"
                           statusbar_visible="bozza,aperto,chiuso,archiviato"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Dettagli">
                            <field name="anno"/>
                            <field name="data_inizio"/>
                            <field name="data_fine"/>
                        </group>
                        <group string="Statistiche">
                            <field name="totale_elaborati"/>
                            <field name="totale_partecipanti"/>
                            <field name="totale_valutati"/>
                            <field name="totale_premiati"/>
                            <field name="media_punteggi_generale"/>
                            <field name="totale_sezioni"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sezioni">
                            <field name="sezione_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Elaborati">
                            <field name="elaborato_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="partecipante_id"/>
                                    <field name="sezione_id"/>
                                    <field name="sottosezione_id"/>
                                    <field name="stato"/>
                                    <field name="media_punteggi"/>
                                    <field name="posizione_ranking"/>
                                </list>
                            </field>
                        </page>
                        <page string="Note">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Edizione: list view -->
    <record id="view_concorso_edizione_list" model="ir.ui.view">
        <field name="name">concorso.edizione.list</field>
        <field name="model">concorso.edizione</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="anno"/>
                <field name="data_inizio"/>
                <field name="data_fine"/>
                <field name="stato"/>
                <field name="totale_elaborati"/>
                <field name="totale_partecipanti"/>
                <field name="totale_valutati"/>
                <field name="totale_premiati"/>
                <field name="media_punteggi_generale"/>
                <field name="totale_sezioni"/>
            </list>
        </field>
    </record>

    <!-- Edizione: search view -->
    <record id="view_concorso_edizione_search" model="ir.ui.view">
        <field name="name">concorso.edizione.search</field>
        <field name="model">concorso.edizione</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="anno"/>
                <filter string="Aperte" name="aperte" domain="[('stato','=','aperto')]"/>
                <filter string="Chiuse" name="chiuse" domain="[('stato','=','chiuso')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Anno" name="group_anno" context="{'group_by': 'anno'}"/>
                    <filter string="Stato" name="group_stato" context="{'group_by': 'stato'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Edizione: action -->
    <record id="action_concorso_edizione" model="ir.actions.act_window">
        <field name="name">Edizioni</field>
        <field name="res_model">concorso.edizione</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Report action -->
    <record id="action_report_statistiche_edizione" model="ir.actions.report">
        <field name="name">Statistiche Edizione</field>
        <field name="model">concorso.edizione</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">concorso_letterario.report_statistiche_edizione</field>
        <field name="report_file">concorso_letterario.report_statistiche_edizione</field>
        <field name="binding_model_id" ref="model_concorso_edizione"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
